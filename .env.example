# Application
APP_ENV=development
APP_NAME=rag
API_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
AUTH_REQUIRED_FOR_CORE_ROUTES=false

# Auth Security
JWT_SECRET_KEY=dev_jwt_secret_change_me_please_rotate_123456
JWT_MIN_SECRET_LENGTH=32
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_MINUTES=10080
OAUTH_STATE_TTL_MINUTES=10
ENABLE_GOOGLE_OAUTH=false
ENABLE_GITHUB_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# Storage / Vector DB
CHROMA_PERSIST_DIR=./data/chroma
VECTOR_COLLECTION_NAME=documents
PDF_STORAGE_DIR=./data/documents

# Ingestion
CHUNK_SIZE=800
CHUNK_OVERLAP=120
MAX_FILE_SIZE_MB=25

# Retrieval & Context
TOP_K_DEFAULT=5
MIN_RETRIEVAL_SCORE=0.0
MAX_CONTEXT_CHARS=12000
MAX_CONTEXT_TOKENS=6000
MAX_PROMPT_TOKENS=8000
RESERVED_RESPONSE_TOKENS=1500
TOKENIZER_STRICT=false
ENABLE_DEBUG_RETRIEVAL=true

# Retrieval Intelligence
ENABLE_RERANKING=false
RERANK_TOP_N=8
RETRIEVAL_NEAR_DUPLICATE_THRESHOLD=0.94
DUPLICATE_SIMILARITY_THRESHOLD=0.90
ENABLE_DIVERSITY_RETRIEVAL=true
DIVERSITY_LAMBDA=0.20
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TIMEOUT_MS=120
RERANKER_MAX_LATENCY_MS=500
THRESHOLD_RECALL_FLOOR=0.70

# Reliability
EXTERNAL_TIMEOUT_SECONDS=25
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_DELAY_SECONDS=0.5
RETRY_MAX_DELAY_SECONDS=8
RETRY_EXPONENTIAL_BACKOFF=true
RETRY_JITTER=true

# Observability
ENABLE_OTEL=false
OTEL_SERVICE_NAME=multimodal-rag-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
